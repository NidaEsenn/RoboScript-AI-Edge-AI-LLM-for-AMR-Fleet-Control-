# Copy to .env and fill in. Never commit your real .env (it's gitignored).

# Generation backend for roboscript/data/synthetic.py
PROVIDER=groq                 # gemini | groq | openai

# Provide the key for the provider you selected above
GROQ_API_KEY=gsk_...          # https://console.groq.com/keys
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey
OPENAI_API_KEY=               # https://platform.openai.com/api-keys

# HuggingFace token — needed for the Llama-3.1 tokenizer in pipeline.py (loss masking)
HF_TOKEN=hf_...               # https://huggingface.co/settings/tokens
